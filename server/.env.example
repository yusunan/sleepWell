# ============================================================
# 睡了么 Backend — Environment Variables
# ============================================================
# Copy to .env and fill in your values.
#
# MySQL connection — two modes (param mode takes priority):
#
#   Mode 1: Self-hosted MySQL (Alibaba Cloud ECS)
#     Set MYSQL_HOST (and optionally MYSQL_USER / MYSQL_PASSWORD / MYSQL_DATABASE)
#
#   Mode 2: Cloud MySQL (PlanetScale / Aiven / etc.)
#     Set MYSQL_URL=mysql://user:pass@host/db
# ============================================================

# --- MySQL (Self-hosted) ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=sleepwell
MYSQL_PASSWORD=your_strong_password_here
MYSQL_DATABASE=sleepwell

# --- JWT ---
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_openssl_rand_hex_32_output
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# --- CORS — your Cloudflare Pages domain ---
CORS_ORIGIN=https://sleepwell-887.pages.dev

# --- Server ---
NODE_ENV=production
PORT=3000
